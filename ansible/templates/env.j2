# Rendered by Ansible on each deploy — DO NOT edit on the server (overwritten).
# Mode 0600, owner tom. Consumed by docker-compose.prod.yml.
IMAGE_TAG={{ image_tag }}

# Mongo admin account (admin DB) — created by the mongo container on first init.
MONGO_ROOT_USERNAME={{ mongo_root_username | default('root') }}
MONGO_ROOT_PASSWORD={{ mongo_root_password }}

# Least-privilege application user (stringpro DB) — created by init-mongo.js.
MONGO_APP_USERNAME={{ mongo_app_username | default('stringpro') }}
MONGO_APP_PASSWORD={{ mongo_app_password }}
